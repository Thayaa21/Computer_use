# ─────────────────────────────────────────────────────────────────────────────
# GhostDev — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000

# Twilio — inbound call webhook
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15550000000

# Slack — bot credentials and target channel
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CHANNEL_ID=C00000000

# Anthropic — Haiku (classifier) + Sonnet (computer use)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# UiPath Orchestrator — OAuth2 client credentials
UIPATH_BASE_URL=https://cloud.uipath.com
UIPATH_TENANT=your_tenant_name
UIPATH_CLIENT_ID=your_uipath_client_id
UIPATH_CLIENT_SECRET=your_uipath_client_secret

# UiPath Robot process keys
UIPATH_TEST_PROCESS_KEY=your_test_process_key
UIPATH_COMMIT_PROCESS_KEY=your_commit_process_key

# Project directory on the local machine (used for snapshots and file operations)
PROJECT_DIR=/path/to/your/project
